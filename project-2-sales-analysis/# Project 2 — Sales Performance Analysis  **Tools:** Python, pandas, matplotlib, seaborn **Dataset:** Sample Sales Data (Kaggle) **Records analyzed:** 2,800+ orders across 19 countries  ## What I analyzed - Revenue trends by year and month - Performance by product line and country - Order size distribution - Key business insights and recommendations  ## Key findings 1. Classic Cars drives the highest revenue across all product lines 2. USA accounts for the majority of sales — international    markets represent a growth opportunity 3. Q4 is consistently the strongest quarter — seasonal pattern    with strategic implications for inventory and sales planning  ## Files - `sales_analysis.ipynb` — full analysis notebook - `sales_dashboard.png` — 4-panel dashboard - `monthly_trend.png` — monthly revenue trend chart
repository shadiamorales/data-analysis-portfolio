      "source": [
        "# Estilo general\n",
        "sns.set_style(\"whitegrid\")\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "fig.suptitle(\"Sales Performance Dashboard\", fontsize=16, fontweight=\"bold\")\n",
        "\n",
        "# Gráfica 1 — Ventas por año\n",
        "ventas_año = df.groupby(\"YEAR\")[\"SALES\"].sum().reset_index()\n",
        "axes[0,0].bar(ventas_año[\"YEAR\"].astype(str), ventas_año[\"SALES\"],\n",
        "              color=[\"#185FA5\", \"#378ADD\", \"#85B7EB\"])\n",
        "axes[0,0].set_title(\"Total Revenue by Year\")\n",
        "axes[0,0].set_ylabel(\"Revenue (USD)\")\n",
        "for i, v in enumerate(ventas_año[\"SALES\"]):\n",
        "    axes[0,0].text(i, v + 5000, f\"${v:,.0f}\", ha=\"center\", fontsize=9)\n",
        "\n",
        "# Gráfica 2 — Ventas por línea de producto\n",
        "ventas_producto = df.groupby(\"PRODUCTLINE\")[\"SALES\"].sum().sort_values()\n",
        "axes[0,1].barh(ventas_producto.index, ventas_producto.values, color=\"#1D9E75\")\n",
        "axes[0,1].set_title(\"Revenue by Product Line\")\n",
        "axes[0,1].set_xlabel(\"Revenue (USD)\")\n",
        "\n",
        "# Gráfica 3 — Ventas por país (top 8)\n",
        "ventas_pais = df.groupby(\"COUNTRY\")[\"SALES\"].sum().sort_values(ascending=False).head(8)\n",
        "axes[1,0].bar(ventas_pais.index, ventas_pais.values, color=\"#D85A30\")\n",
        "axes[1,0].set_title(\"Top 8 Countries by Revenue\")\n",
        "axes[1,0].set_ylabel(\"Revenue (USD)\")\n",
        "axes[1,0].tick_params(axis=\"x\", rotation=45)\n",
        "\n",
        "# Gráfica 4 — Distribución del tamaño de órdenes\n",
        "axes[1,1].hist(df[\"SALES\"], bins=30, color=\"#533AB7\", edgecolor=\"white\")\n",
        "axes[1,1].set_title(\"Order Size Distribution\")\n",
        "axes[1,1].set_xlabel(\"Order Value (USD)\")\n",
        "axes[1,1].set_ylabel(\"Frequency\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"sales_dashboard.png\", dpi=150, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "print(\"Dashboard guardado como sales_dashboard.png\")"
