        "plt.fill_between(tendencia[\"MONTH\"], tendencia[\"SALES\"], alpha=0.1, color=\"#185FA5\")\n",
        "plt.title(f\"Monthly Revenue Trend — {mejor_año}\", fontsize=13)\n",
        "plt.xlabel(\"Month\")\n",
