    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "\n",
        "# Tabla 1: ventas por orden\n",
        "ventas = pd.DataFrame({\n",
        "    \"orden_id\": [1, 2, 3, 4, 5],\n",
        "    \"cliente_id\": [101, 102, 103, 101, 104],\n",
        "    \"producto\": [\"Plan Basic\", \"Plan Pro\", \"Plan Basic\", \"Plan Pro\", \"Plan Enterprise\"],\n",
        "    \"valor\": [500, 1200, 500, 1200, 3000],\n",
        "    \"mes\": [\"Enero\", \"Enero\", \"Febrero\", \"Febrero\", \"Febrero\"]\n",
        "})\n",
        "\n",
        "# Tabla 2: información de clientes\n",
        "clientes = pd.DataFrame({\n",
        "    \"cliente_id\": [101, 102, 103, 104],\n",
        "    \"nombre\": [\"Acme Corp\", \"TechStart\", \"BlueSky\", \"NovaCo\"],\n",
        "    \"pais\": [\"USA\", \"Canada\", \"USA\", \"Mexico\"],\n",
        "    \"segmento\": [\"Enterprise\", \"SMB\", \"SMB\", \"Enterprise\"]\n",
        "})\n",
        "\n",
        "print(\"=== Tabla ventas ===\")\n",
        "print(ventas)\n",
        "print(\"\\n=== Tabla clientes ===\")\n",
        "print(clientes)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "P5PlZXMKIe6a",
        "outputId": "781376b9-be12-44c3-ef9e-4945096fcb28"
      },
      "execution_count": 2,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "=== Tabla ventas ===\n",
            "   orden_id  cliente_id         producto  valor      mes\n",
            "0         1         101       Plan Basic    500    Enero\n",
            "1         2         102         Plan Pro   1200    Enero\n",
            "2         3         103       Plan Basic    500  Febrero\n",
            "3         4         101         Plan Pro   1200  Febrero\n",
            "4         5         104  Plan Enterprise   3000  Febrero\n",
            "\n",
            "=== Tabla clientes ===\n",
            "   cliente_id     nombre    pais    segmento\n",
            "0         101  Acme Corp     USA  Enterprise\n",
            "1         102  TechStart  Canada         SMB\n",
            "2         103    BlueSky     USA         SMB\n",
            "3         104     NovaCo  Mexico  Enterprise\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# INNER JOIN — solo los que coinciden en ambas tablas\n",
        "inner = pd.merge(ventas, clientes, on=\"cliente_id\", how=\"inner\")\n",
        "print(\"\\n=== INNER JOIN ===\")\n",
        "print(inner)\n",
        "\n",
        "# LEFT JOIN — todos los de ventas, aunque no tengan cliente\n",
        "left = pd.merge(ventas, clientes, on=\"cliente_id\", how=\"left\")\n",
        "print(\"\\n=== LEFT JOIN ===\")\n",
        "print(left)\n",
        "\n",
        "# Ahora analiza el resultado combinado\n",
        "print(\"\\n=== Ventas por país ===\")\n",
        "print(inner.groupby(\"pais\")[\"valor\"].sum())\n",
        "\n",
        "print(\"\\n=== Ventas por segmento ===\")\n",
        "print(inner.groupby(\"segmento\")[\"valor\"].agg([\"sum\", \"count\", \"mean\"]).round(2))\n",
        "\n",
        "print(\"\\n=== Producto más vendido por país ===\")\n",
        "print(inner.groupby([\"pais\", \"producto\"])[\"valor\"].sum().reset_index())"
      ],
