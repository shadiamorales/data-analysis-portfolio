    },
    {
      "cell_type": "code",
      "source": [
        "# Calcular comisión del 8% por venta\n",
        "inner[\"comision\"] = (inner[\"valor\"] * 0.08).round(2)\n",
        "\n",
        "# Total por cliente\n",
        "resumen = inner.groupby(\"nombre\").agg(\n",
        "    total_ventas=(\"valor\", \"sum\"),\n",
        "    num_ordenes=(\"orden_id\", \"count\"),\n",
        "    comision_total=(\"comision\", \"sum\")\n",
        ").reset_index()\n",
        "\n",
        "print(\"\\n=== Resumen por cliente ===\")\n",
        "print(resumen)\n",
        "\n",
        "# Guardar resultado como CSV\n",
        "resumen.to_csv(\"resumen_clientes.csv\", index=False)\n",
        "print(\"\\nArchivo guardado: resumen_clientes.csv\")"
